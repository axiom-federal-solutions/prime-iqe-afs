# =============================================================
# PRIME IQE — Environment Variables
# Copy this file to .env for local development
# For production: add these as GitHub Secrets in your repository
# NEVER commit .env to GitHub — it's in .gitignore
# =============================================================

# --- SUPABASE (Database) ---
# Get these from: supabase.com → Your Project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- ANTHROPIC (AI — Claude Haiku + Sonnet) ---
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- SENDGRID (Email delivery) ---
# Get from: sendgrid.com → Settings → API Keys → Create API Key (Mail Send only)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
FROM_EMAIL=PrimeOpps1@gmail.com
FROM_NAME=PRIME — Axiom Federal Solutions

# --- SAM.GOV (Federal opportunity scanner) ---
# Get from: sam.gov → Sign In → Account Details → API Key
# Free account gets 1,000 calls/day — we use ~50/day across 4 scans
SAM_API_KEY=your_sam_gov_api_key_here

# --- COMPANY INFO ---
# Walker Contractors LLC / Axiom Federal Solutions
CAGE_CODE=your_cage_code_here
BONDING_COMPANY=your_surety_company_name_here

# --- LOCAL DEV ONLY (not used in GitHub Actions) ---
# NODE_ENV=development
